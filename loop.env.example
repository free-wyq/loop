# loop-orchestrator 环境变量配置（给调度器用）
#
# 为什么需要它：cron / systemd / hermes cron 这类非交互调度器跑的是干净 env，
# 不会 source ~/.bashrc——你写在 ~/.bashrc 里的 ANTHROPIC_API_KEY 它们拿不到。
# 放这份文件后，orchestrator 启动会自动读进 process.env（已 export 的不覆盖）。
# 路径默认 ~/.config/loop.env；想换路径：export LOOP_ENV_FILE=/path/to/your.env
#
# 拷到 ~/.config/loop.env 后改成你的值：
#   cp ~/.local/share/loop/loop.env.example ~/.config/loop.env && chmod 600 ~/.config/loop.env

# ---- 鉴权 / 模型（必填）----
ANTHROPIC_API_KEY=sk-...                      # 换成你的密钥
# 走代理（GLM/自托管/中转）才填；官方 Anthropic API 不用：
# ANTHROPIC_BASE_URL=http://192.168.241.10:3000
# 指定模型（走代理时按代理支持的模型名填）：
# ANTHROPIC_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.1
# CLAUDE_CODE_SUBAGENT_MODEL=glm-5.1

# ---- 限额（0 = 不限，默认即不限；自托管/免费模型护栏纯属挡路，别设正数）----
# 想要护栏再给正数：
# LOOP_MAX_TURNS=60              # 单任务最大轮数
# LOOP_MAX_BUDGET_PER_TASK=3      # 单任务美元上限
# LOOP_MAX_BUDGET_TOTAL=50        # 全程美元上限（24h 护栏）
# LOOP_BOOTSTRAP_MAX_TURNS=20     # bootstrap（任务拆解）最大轮数
# LOOP_BOOTSTRAP_MAX_BUDGET=5     # bootstrap 美元上限
# LOOP_STALL_LIMIT=3              # 同任务连续零改动 N 次标阻塞
# LOOP_ABORT_TIMEOUT_MIN=60       # 单任务超 N 分钟无进展则 abort 重试
# LOOP_SESSION_RETRY_LIMIT=3      # 当前任务连续 ctx 撑爆 N 次标阻塞
